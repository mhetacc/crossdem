@article{cova_new_2025,
	title = {A new database for {Italian} parliamentary speeches: introducing the \textit{{ItaParlCorpus}} dataset},
	volume = {55},
	copyright = {http://creativecommons.org/licenses/by/4.0/},
	issn = {0048-8402, 2057-4908},
	shorttitle = {A new database for {Italian} parliamentary speeches},
	url = {https://www.cambridge.org/core/product/identifier/S0048840225000061/type/journal_article},
	doi = {10.1017/ipo.2025.6},
	abstract = {A common challenge in studying Italian parliamentary discourse is the lack of accessible, machine-readable, and systematized parliamentary data. To address this, this article introduces the ItaParlCorpus dataset, a new, annotated, machine-readable collection of Italian parliamentary plenary speeches for the Camera dei Deputati, the lower house of Parliament, spanning from 1948 to 2022. This dataset encompasses 470 million words and 2.4 million speeches delivered by 5830 unique speakers representing 77 different political parties. The files are designed for easy processing and analysis using widely-used programming languages, and they include metadata such as speaker identification and party affiliation. This opens up opportunities for in-depth analyses on a variety of topics related to parliamentary behavior, elite rhetoric, and the salience of political themes, exploring how these vary across party families and over time.},
	language = {en},
	number = {1},
	urldate = {2026-03-31},
	journal = {Italian Political Science Review/Rivista Italiana di Scienza Politica},
	author = {Cova, Joshua},
	month = mar,
	year = {2025},
	pages = {77--86},
	file = {PDF:/home/mhetac/Zotero/storage/DI2V7PWI/Cova - 2025 - A new database for Italian parliamentary speeches introducing the ItaParlCorpus dataset.pdf:application/pdf},
}

